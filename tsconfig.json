{
  "compilerOptions": {
    "target": "es2020",
    "module": "es2022",
    "lib": [
      "es2020"
    ],
    "declaration": false,
    "sourceMap": true,
    "outDir": "./lib",
    "strict": true,
    "noImplicitAny": false,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": [
    "src/",
    "api/"
  ],
  "compileOnSave": false
}
